# Timberborn Automation - Docker Environment Variables
# Copy this file to .env and customize as needed

# Game API URL
# Default uses host.docker.internal (works on Docker Desktop)
# On Linux, you may need to set extra_hosts in docker-compose.yml or use host IP
GAME_API_URL=http://host.docker.internal:8080

# Controller webhook port (default: 8081)
WEBHOOK_PORT=8081

# Dashboard port (default: 8000)
DASHBOARD_PORT=8000

# Operating mode: webhook, polling, or hybrid
# MODE=webhook

# Polling interval in seconds (for polling/hybrid mode)
# POLLING_INTERVAL=5
